{
  "repository": "crazythecoder/IW4MAdmin-SebzAntiCheat",
  "stateFile": "/var/lib/iw4x-anticheat-updater/state.json",
  "backupDirectory": "/var/lib/iw4x-anticheat-updater/backups",
  "initialization": {
    "directories": [
      {"path": "/opt/iw4x-anticheat", "mode": "750"},
      {"path": "/var/lib/iw4x-anticheat-updater/backups", "mode": "750"}
    ],
    "seedFiles": [
      {
        "source": "anticheat-discord-config.example.json",
        "destination": "/opt/iw4x-anticheat/anticheat-discord-config.json.example",
        "mode": "640"
      }
    ],
    "commands": []
  },
  "autoApply": {
    "updater": true,
    "dashboard": true,
    "helpers": true,
    "gsc": false
  },
  "targets": {
    "updater": [
      {
        "source": "updater/anticheat-updater.py",
        "destination": "/opt/iw4x-anticheat-updater/anticheat-updater.py"
      }
    ],
    "dashboard": [
      {
        "source": "iw4madmin/Plugins/AnticheatMetrics.js",
        "destination": "/path/to/IW4MAdmin/Plugins/AnticheatMetrics.js"
      }
    ],
    "helpers": [
      {
        "source": "anticheat-discord-watcher.js",
        "destination": "/opt/iw4x-anticheat/anticheat-discord-watcher.js"
      },
      {
        "source": "iw4m-client-map.py",
        "destination": "/opt/iw4x-anticheat/iw4m-client-map.py"
      },
      {
        "source": "iw4madmin/Plugins/anticheat_iw4m_flag_worker.py",
        "destination": "/path/to/IW4MAdmin/Plugins/anticheat_iw4m_flag_worker.py"
      }
    ],
    "gsc": [
      {
        "source": "maps/mp/gametypes/_anticheat_suspicion.gsc",
        "destination": "/path/to/server/userraw/maps/mp/gametypes/_anticheat_suspicion.gsc"
      },
      {
        "source": "maps/mp/gametypes/_killstreak_logger.gsc",
        "destination": "/path/to/server/userraw/maps/mp/gametypes/_killstreak_logger.gsc"
      }
    ]
  },
  "restartCommands": {
    "updater": [],
    "dashboard": [],
    "helpers": [],
    "gsc": []
  },
  "validationCommands": [
    ["node", "--check", "/path/to/IW4MAdmin/Plugins/AnticheatMetrics.js"],
    ["node", "--check", "/opt/iw4x-anticheat/anticheat-discord-watcher.js"]
  ],
  "maintenanceCommands": [],
  "healthCheckCommands": [],
  "healthChecks": [
    {
      "name": "IW4MAdmin container health",
      "command": ["docker", "inspect", "--format={{.State.Health.Status}}", "iw4madmin"],
      "expectedOutput": "^healthy$",
      "attempts": 6,
      "delaySeconds": 10,
      "repairCommands": [["docker", "restart", "iw4madmin"]]
    },
    {
      "name": "Anti-cheat watcher service",
      "command": ["systemctl", "is-active", "--quiet", "anticheat-discord-watcher"],
      "attempts": 3,
      "delaySeconds": 5,
      "repairCommands": [["systemctl", "restart", "anticheat-discord-watcher"]]
    }
  ]
}
